OBJ = kinds.o constants.o formats.o prun.o allocate_arrays.o HM_gen.o hm_test.o main.o

OBJ_LIST = $(foreach O, ${OBJ}, $(OBJDIR)/$(O))

$(EXE) : $(OBJ_LIST)
	$(COMPILER) -o $(EXE) $(OBJ_LIST) $(LIBS) $(MT_FLAG)

################################### SOURCE FILES #########################################
$(OBJDIR)/kinds.o: $(SOURCE)/kinds.F90
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/constants.o: $(SOURCE)/constants.F90 $(OBJDIR)/kinds.o
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/formats.o: $(SOURCE)/formats.F90
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/prun.o: $(SOURCE)/prun.F90
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/allocate_arrays.o: $(SOURCE)/allocate_arrays/* $(OBJDIR)/kinds.o \
$(OBJDIR)/prun.o
	$(COMPILER) -c $(FLAGS) $(SOURCE)/allocate_arrays/allocate_arrays.F90 -o $@

$(OBJDIR)/array_dyna.o: $(SOURCE)/array_dyna/array_dyna.F90 \
$(OBJDIR)/allocate_arrays.o
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/HM_gen.o: $(SOURCE)/HM_models/HM_gen.F90 $(OBJDIR)/formats.o \
$(OBJDIR)/allocate_arrays.o
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/hm_test.o: $(SOURCE)/HM_models/hm_test.F90 $(OBJDIR)/HM_gen.o
	$(COMPILER) -c $(FLAGS) $< -o $@

$(OBJDIR)/main.o: main.F90 $(OBJDIR)/hm_test.o
	$(COMPILER) -c $(FLAGS) $< -o $@
##########################################################################################